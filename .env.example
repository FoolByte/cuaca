# Database
DATABASE_URL=postgresql://weather_user:weather_pass@localhost:5432/weather_dwh
POSTGRES_USER=weather_user
POSTGRES_PASSWORD=weather_pass
POSTGRES_DB=weather_dwh
POSTGRES_PORT=5432

# Weather Provider
WEATHER_PROVIDER=bmkg          # bmkg | openweather | mock
BMKG_API_BASE_URL=
OPENWEATHER_API_KEY=

# Scheduler
ETL_SCHEDULE_INTERVAL_MINUTES=10

# Airflow (Phase 5)
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW_UID=50000
